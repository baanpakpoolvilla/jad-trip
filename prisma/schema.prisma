generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // ใช้ pooler (6543 + pgbouncer) บน serverless ได้ — ต้องมี DIRECT_URL แบบ direct สำหรับ migrate/db push
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ORGANIZER
}

enum TripStatus {
  DRAFT
  PUBLISHED
  CLOSED
  CANCELLED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  EXPIRED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  /// ลิงก์ย่อรายการทริปของผู้จัด เช่น /o/{brochureShareCode} → /trips?o=…
  brochureShareCode String? @unique
  phone        String?
  /// แสดงในการ์ดผู้จัดบนหน้าทริป (URL รูป)
  avatarUrl    String?
  /// แนะนำตัว / ประสบการณ์นำทริป
  bio          String   @default("")
  /// ลิงก์โซเชียล / เว็บ (แสดงในหน้าโปรไฟล์สาธารณะเมื่อกรอก)
  socialWebsite   String?
  socialLine      String?
  socialFacebook  String?
  socialInstagram String?
  socialTiktok    String?
  socialYoutube   String?
  socialX         String?
  /// เลขพร้อมเพย์ / เลขประจำตัวผู้เสียภาษี (ตัวเลขอย่างเดียวหรือมีขีด) — ใช้สร้าง QR และตรวจสลิป
  payoutPromptPayId String?
  /// รูป QR โอนเงิน (อัปโหลด) — แสดงเพิ่มในหน้าชำระของผู้จอง
  payoutQrImageUrl        String?
  /// ชื่อธนาคาร / สาขา (ข้อความสั้น)
  payoutBankName          String?
  /// ชื่อบัญชีผู้รับโอน
  payoutBankAccountName   String?
  /// เลขบัญชีธนาคาร
  payoutBankAccountNumber String?
  role         Role     @default(ORGANIZER)
  /// เปิดแล้วผู้จัดคนอื่นสามารถค้นหาและเลือกเป็นผู้นำทริปในฟอร์มทริปได้
  isGuide      Boolean  @default(false)
  /// วันที่ผู้ใช้ทำ onboarding เสร็จสิ้น (null = ยังไม่เสร็จ)
  onboardingCompletedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  trips        Trip[]
  guidedTrips  Trip[]   @relation("TripGuide")
  notifications Notification[]
  passwordResetTokens PasswordResetToken[]
}

/// โทเคนรีเซ็ตรหัสผ่าน (เก็บเฉพาะ hash ของค่าที่ส่งในลิงก์อีเมล)
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Trip {
  id               String      @id @default(cuid())
  /// ลิงก์ย่อสาธารณะ เช่น /t/{shareCode} → รายละเอียดทริป (ไม่เปลี่ยนหลังสร้าง)
  shareCode        String?     @unique
  organizerId      String
  organizer        User        @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  /// ผู้นำทริป (ดึงรูป/ชื่อ/ไบโอจากโปรไฟล์ผู้ใช้ที่เปิดโหมดไกด์)
  guideUserId      String?
  guide            User?       @relation("TripGuide", fields: [guideUserId], references: [id], onDelete: SetNull)
  title            String
  shortDescription String
  description      String
  meetPoint        String
  /// พิกัดจุดนัดพบ / เช็คอิน (WGS84) — ว่างได้ถ้าไม่เลือกจากแผนที่
  meetPointLat     Float?
  meetPointLng     Float?
  /// ชื่อสถานที่จากแผนที่ (OpenStreetMap / Nominatim) — แสดงในหน้ารายละเอียด
  destinationName  String   @default("")
  /// พิกัดจุดหมายปลายทาง (WGS84) — ว่างได้ถ้าไม่เลือกจากแผนที่
  destinationLat   Float?
  destinationLng   Float?
  startAt          DateTime
  endAt            DateTime
  maxParticipants  Int
  pricePerPerson   Int
  bookingClosesAt  DateTime?
  policyNotes      String      @default("")
  /// ลิงก์กลุ่ม (LINE, Facebook Group ฯลฯ) สำหรับผู้จองที่ยืนยันแล้ว
  groupUrl         String?
  /// URL รูปหน้าปก (https://…)
  coverImageUrl    String?
  /// URL รูปเพิ่มเติม ทีละบรรทัด
  galleryImageUrls String      @default("")
  guideDetails     String      @default("")
  /// กำหนดการเดินทาง / เส้นทางโดยย่อ
  itinerary        String      @default("")
  travelNotes      String      @default("")
  highlights       String      @default("")
  packingList      String      @default("")
  safetyNotes      String      @default("")
  guideProvides    String      @default("")
  status           TripStatus  @default(DRAFT)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  bookings         Booking[]

  @@index([organizerId])
  @@index([guideUserId])
  @@index([status, startAt])
}

model Booking {
  id                 String         @id @default(cuid())
  tripId             String
  trip               Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  participantName    String
  participantEmail   String
  participantPhone   String
  status             BookingStatus  @default(PENDING_PAYMENT)
  viewToken          String         @unique
  expiresAt          DateTime
  stripeSessionId    String?        @unique
  paidAt             DateTime?
  /// transRef จาก EasySlip — กันสลิปซ้ำระดับแอป
  slipTransRef       String?        @unique
  slipVerifiedAt     DateTime?
  /// URL รูปสลิปที่ผู้จองอัปโหลด (เก็บใน Supabase Storage) — แสดงในหน้าผู้จัด
  slipImageUrl       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([tripId])
  @@index([tripId, status])
}

/// การตั้งค่าเว็บไซต์ (singleton — id = "1" เสมอ)
model SiteSettings {
  id              String   @id @default("1")
  siteName        String   @default("Say Hi Trip")
  siteTagline     String   @default("ส่ง Trip ให้ทุกคน")
  siteDescription String   @default("แพลตฟอร์มจัดทริปกลุ่มแบบอบอุ่น — นำเสนอทริป รับจอง ตามสถานะชำระเงิน และส่งลิงก์ให้เพื่อนหรือลูกค้าได้ในที่เดียว")
  /// URL รูปโลโก้ (https://…) — แสดงในเฮดเดอร์และ Open Graph
  logoUrl         String?
  /// URL favicon (https://…) — ใช้ใน <head>
  faviconUrl      String?
  updatedAt       DateTime @updatedAt
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  title     String
  message   String
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}
