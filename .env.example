# PostgreSQL
# ใช้พอร์ต 5433 ตาม docker-compose.yml (กันชนกับ Postgres บนเครื่องที่พอร์ต 5432)
DATABASE_URL="postgresql://dernpa:dernpa@127.0.0.1:5433/dernpa?schema=public"

# NextAuth — สร้างด้วย `openssl rand -base64 32`
AUTH_SECRET=""

# Production (Vercel): URL สาธารณะของเว็บ — ต้องตรงกับโดเมนจริง
# AUTH_URL="https://your-project.vercel.app"

# URL ของเว็บ (Stripe redirect + ลิงก์ในแอป) — บน Vercel ให้ตั้งเหมือน AUTH_URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# รหัส seed (ไม่บังคับ — มีค่าเริ่มต้นใน prisma/seed.ts สำหรับ dev เท่านั้น)
# SEED_ADMIN_PASSWORD=""
# SEED_ORGANIZER_PASSWORD=""
