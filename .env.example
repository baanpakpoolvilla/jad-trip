# --- PostgreSQL -----------------------------------------------------------
# เลือกอย่างใดอย่างหนึ่ง: Supabase (แนะนำบนคลาวด์) หรือ Docker บนเครื่อง
#
# Supabase: Dashboard → Project Settings → Database → Connection string (URI)
# ใส่รหัสผ่านจริงแทน <PASSWORD> และ project ref แทน <PROJECT-REF>
#
# DATABASE_URL = แบบที่แอปใช้ (local ใช้ direct ได้)
# DIRECT_URL   = ต้องเป็น Direct (port 5432) เสมอ — สำหรับ prisma db push / migrate
#               ถ้า local ใช้แค่ direct ให้ตั้งค่าเท่ากับ DATABASE_URL
#
# DATABASE_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres?schema=public"
# DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres?schema=public"
#
# --- หรือ Docker บนเครื่อง (พอร์ต 5433 ตาม docker-compose.yml) ----------
DATABASE_URL="postgresql://dernpa:dernpa@127.0.0.1:5433/dernpa?schema=public"
DIRECT_URL="postgresql://dernpa:dernpa@127.0.0.1:5433/dernpa?schema=public"

# Supabase (JS client / middleware) — Dashboard → Project Settings → API
# ไม่บังคับถ้าใช้แค่ NextAuth + Prisma; บังคับถ้าจะใช้ Supabase Auth หรือเรียกจาก @/utils/supabase/*
# มักใส่ใน .env.local — ใช้กับ @supabase/ssr (middleware refresh session)
# NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<publishable / anon key>"

# NextAuth — สร้างด้วย `openssl rand -base64 32`
AUTH_SECRET=""

# Production (Vercel): URL สาธารณะของเว็บ — ต้องตรงกับโดเมนจริง
# AUTH_URL="https://your-project.vercel.app"

# URL ของเว็บ (Stripe redirect + ลิงก์ในแอป) — บน Vercel ให้ตั้งเหมือน AUTH_URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- อีเมล (รีเซ็ตรหัสผ่าน) -------------------------------------------------
# เลือกอย่างใดอย่างหนึ่ง:
# 1) Connection string (เช่น Gmail / SendGrid SMTP)
# SMTP_URL="smtps://user:pass@smtp.example.com:465"
#
# 2) แยกค่า
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
#
# ผู้ส่ง (ไม่บังคับ — ถ้าว่างจะใช้ SMTP_USER หรือค่าเริ่มต้น)
# EMAIL_FROM="JustTrip <noreply@yourdomain.com>"

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# EasySlip — ตรวจสลิปโอนไทย https://document.easyslip.com/th/
EASYSLIP_API_KEY=""

# ค้นหาสถานที่ (Nominatim) — ไม่บังคับ ระบบจะใส่ User-Agent จาก NEXT_PUBLIC_APP_URL ให้
# NOMINATIM_USER_AGENT="JustTrip/1.0 (https://your-domain.example/contact)"

# รหัส seed (ไม่บังคับ — ค่าเริ่มต้นตรง docs/demo-accounts.md)
# SEED_ADMIN_PASSWORD=""
# SEED_ORGANIZER_PASSWORD=""
# SEED_GUIDE_PASSWORD=""
